rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // For most collections, we allow any authenticated user to read and write.
    // This provides flexibility during development.
    match /cases/{caseId} {
      allow read, write: if request.auth != null;
    }

    match /equipment/{equipmentId} {
      allow read, write: if request.auth != null;
    }

    match /maintenance/{maintenanceId} {
      allow read, write: if request.auth != null;
    }

    match /schedules/{scheduleId} {
      allow read, write: if request.auth != null;
    }
    
    match /routine-work/{workId} {
      allow read, write: if request.auth != null;
    }

    match /routine-work-tasks/{taskId} {
      allow read, write: if request.auth != null;
    }

    match /notes/{noteId} {
      allow read, write: if request.auth != null;
    }

    // For the engineers collection, we can be more explicit as requested.
    match /engineers/{engineerId} {
      // Any authenticated user can read the list of engineers.
      allow read: if request.auth != null;
      
      // Any authenticated user can also add, update, or delete engineers.
      // We will list them explicitly for clarity.
      allow create, update, delete: if request.auth != null;
    }
  }
}
